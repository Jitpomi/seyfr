<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Seyfr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Seyfr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SEYFR">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <local:TabBackgroundConverter x:Key="TabBackgroundConverter" />
            <local:TabForegroundConverter x:Key="TabForegroundConverter" />
            <SolidColorBrush x:Key="HoverBrush" Color="#F5F5F5" />
            
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{StaticResource HoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter 
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:TabTitleConverter x:Key="TabTitleConverter" />
            <local:TabSubtitleConverter x:Key="TabSubtitleConverter" />
            <local:TabVisibilityConverter x:Key="TabVisibilityConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" TrueValue="SemiBold" FalseValue="Normal" />
            <local:BoolToFontWeightConverter x:Key="InverseBoolToFontWeightConverter" TrueValue="Normal" FalseValue="SemiBold" />
            <local:FolderModeGlyphConverter x:Key="FolderModeGlyphConverter" />
            <local:IconBubbleBackgroundConverter x:Key="IconBubbleBackgroundConverter" />
            <local:TabFontWeightConverter x:Key="TabFontWeightConverter" />
            <local:TabStatusTextConverter x:Key="TabStatusTextConverter" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
            <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <local:InverseBoolToOpacityConverter x:Key="InverseBoolToOpacityConverter" />
            <!-- Override NavigationView backgrounds to allow full-window Mica transparency -->
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Background="Transparent" Canvas.ZIndex="1" Margin="48,0,0,0">
            <!-- Draggable region for ExtendsContentIntoTitleBar -->
            <StackPanel Spacing="12" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image Width="18" Height="18" Source="ms-appx:///Assets/sidebar_logo.png" />
                <TextBlock Text="SEYFR" FontSize="13" FontWeight="SemiBold" CharacterSpacing="50" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView" 
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        IsBackButtonVisible="Collapsed" 
                        IsSettingsVisible="False"
                        SelectionChanged="NavView_SelectionChanged"
                        PaneDisplayMode="Auto"
                        IsTitleBarAutoPaddingEnabled="True">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Send" Content="Send" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE898;" FontFamily="Segoe Fluent Icons" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Receive" Content="Receive">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" FontFamily="Segoe Fluent Icons" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Support" Content="Support">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE00B;" FontFamily="Segoe Fluent Icons" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="16,16" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" Visibility="{Binding ElementName=NavView, Path=IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabStatusTextConverter}, Mode=OneWay}" FontSize="11" Opacity="0.6" Visibility="{Binding ElementName=NavView, Path=IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <!-- Main Content -->
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,16" Spacing="4">
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabTitleConverter}, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabSubtitleConverter}, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Send View -->
                <StackPanel Grid.Row="1"
            Spacing="16"
            HorizontalAlignment="Stretch"
            MaxWidth="720"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Send, Mode=OneWay}">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <!-- Drop Area -->
                    <StackPanel Spacing="16"
                HorizontalAlignment="Stretch"
                Visibility="{Binding HasSelectedFile, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">

                        <local:HandCursorGrid x:Name="DropAreaGrid"
                              MinHeight="280"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              AllowDrop="True"
                              DragOver="DropArea_DragOver"
                              DragLeave="DropArea_DragLeave"
                              DragEnter="DropArea_DragEnter"
                              Drop="DropArea_Drop"
                              Tapped="DropArea_Tapped">

                            <!-- Dynamic Wave Rings generated in C# -->
                            <Canvas x:Name="RingsCanvas" Width="280" Height="280" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />

                            <FontIcon Glyph="{Binding IsFolderMode, Converter={StaticResource FolderModeGlyphConverter}}"
                                    FontSize="28"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            <!-- Drag-over accent ring overlay -->
                            <Border x:Name="DragOverlay"
                                    CornerRadius="20"
                                    BorderThickness="2"
                                    BorderBrush="{StaticResource AccentBorderBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                        </local:HandCursorGrid>

                        <StackPanel Spacing="4"
                    HorizontalAlignment="Center">

                            <TextBlock Text="Drag &amp; drop files here"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.7"
                       HorizontalAlignment="Center" />

                            <local:HandCursorButton Content="or click to browse"
                             FontSize="14"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             Click="BrowseButton_Click"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0" />
                        </StackPanel>

                        <!-- Toggle -->
                        <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">

                            <TextBlock Text="File mode"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                VerticalAlignment="Center"
                                FontWeight="{Binding IsFolderMode, Converter={StaticResource InverseBoolToFontWeightConverter}}"
                                Opacity="{Binding IsFolderMode, Converter={StaticResource InverseBoolToOpacityConverter}}" />

                            <ToggleSwitch IsOn="{Binding IsFolderMode, Mode=TwoWay}"
                                OnContent=""
                                OffContent=""
                                MinWidth="0"
                                Width="40" />

                            <TextBlock Text="Folder mode"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                VerticalAlignment="Center"
                                FontWeight="{Binding IsFolderMode, Converter={StaticResource BoolToFontWeightConverter}}"
                                Opacity="{Binding IsFolderMode, Converter={StaticResource BoolToOpacityConverter}}" />
                        </StackPanel>

                    </StackPanel>

                    <!-- Ticket Card -->
                    <Border Visibility="{Binding HasTicket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource OverlayCornerRadius}"
                Padding="24">

                        <StackPanel Spacing="16">

                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                                    <TextBlock Text="Transfer Ticket"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                                </StackPanel>

                                <local:HandCursorButton Padding="10,6"
                                        HorizontalAlignment="Right"
                                        CornerRadius="8"
                                        Background="Transparent"
                                        BorderThickness="0.5"
                                        Command="{Binding ClearSendCommand, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE894;" FontSize="12" />
                                        <TextBlock Text="Clear" FontSize="12" FontWeight="Medium" />
                                    </StackPanel>
                                </local:HandCursorButton>
                            </Grid>

                            <!-- QR Code -->
                            <Border Width="200"
                                    Height="200"
                                    Padding="16"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Image Source="{Binding TicketQrImage, Mode=OneWay}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="12,12">
                                <TextBlock Text="{Binding Ticket, Mode=OneWay}"
                       FontSize="11"
                       FontFamily="Consolas"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True" />
                            </Border>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <local:HandCursorButton Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,12"
                                        CornerRadius="{ThemeResource ControlCornerRadius}"
                                        Command="{Binding CopyTicketCommand, Mode=OneWay}"
                                        BorderBrush="{ThemeResource SystemAccentColor}"
                                        BorderThickness="1"
                                        Background="Transparent"
                                        Foreground="{ThemeResource SystemAccentColor}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="15" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe Fluent Icons" />
                                        <TextBlock Text="Copy" FontSize="15" FontWeight="Medium" Foreground="{ThemeResource SystemAccentColor}" />
                                    </StackPanel>
                                </local:HandCursorButton>

                                <local:HandCursorButton Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,12"
                                        CornerRadius="{ThemeResource ControlCornerRadius}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Background="{ThemeResource SystemAccentColor}"
                                        Foreground="White"
                                        Command="{Binding ShareTicketCommand, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE72D;" FontSize="15" Foreground="White" FontFamily="Segoe Fluent Icons" />
                                        <TextBlock Text="Share" FontSize="15" FontWeight="Medium" Foreground="White" />
                                    </StackPanel>
                                </local:HandCursorButton>
                            </Grid>
                        </StackPanel>
                    </Border>



                </StackPanel>

                <!-- Receive View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Stretch"
            MaxWidth="720"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Receive, Mode=OneWay}">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <!-- Ticket Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            Padding="24"
            MaxWidth="720"
            HorizontalAlignment="Stretch">

                        <StackPanel Spacing="18">

                            <Grid>
                                <TextBlock Text="Ticket"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <local:HandCursorButton Padding="8,4"
                                            CornerRadius="6"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding PasteTicketCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE77F;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" />
                                            <TextBlock Text="Paste" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                    <local:HandCursorButton Padding="8,4"
                                            CornerRadius="6"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding ClearTicketCommand, Mode=OneWay}"
                                            Visibility="{Binding HasTicketInput, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Clear" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                </StackPanel>
                            </Grid>

                            <TextBox Text="{Binding TicketInput, Mode=TwoWay}"
                                     AutomationProperties.Name="Ticket Input"
                                     TextChanged="TicketInput_TextChanged"
                                     PlaceholderText="Paste ticket here..."
                     AcceptsReturn="True"
                     MinHeight="72"
                     TextWrapping="Wrap"
                     Padding="10"
                     FontFamily="Consolas"
                     FontSize="11"
                     CornerRadius="{ThemeResource ControlCornerRadius}" />
                        </StackPanel>
                    </Border>

                    <!-- Save Location Card -->
                    <local:HandCursorButton HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Save Location"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding SelectDestinationCommand, Mode=OneWay}"
                            MaxWidth="720">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource OverlayCornerRadius}"
                                Padding="24">
                            <StackPanel Spacing="20">
                                <!-- Title -->
                                <TextBlock Text="Save Location"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <!-- Folder Info -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <FontIcon Grid.Column="0" 
                                              Glyph="&#xE8B7;" 
                                              FontSize="20" 
                                              Foreground="{ThemeResource SystemAccentColor}" 
                                              Margin="0,0,16,0" />
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DestinationName, Mode=OneWay}" 
                                               Style="{StaticResource BodyTextBlockStyle}" 
                                               VerticalAlignment="Center" />
                                    
                                    <FontIcon Grid.Column="2" 
                                              Glyph="&#xE76C;" 
                                              FontSize="14" 
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                              VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </local:HandCursorButton>

                    <!-- Receive Button -->
                    <local:HandCursorButton HorizontalAlignment="Stretch"
            AutomationProperties.Name="Receive File"
            Padding="0,12"
            CornerRadius="{ThemeResource ControlCornerRadius}"
            Command="{Binding ReceiveCommand, Mode=OneWay}"
            IsEnabled="{Binding HasTicketInput, Mode=OneWay}"
            BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
            BorderThickness="1"
            Background="Transparent">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE896;" FontSize="18" />
                            <TextBlock Text="Receive File" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                    </local:HandCursorButton>



                    <TextBlock Text="Once you enter a valid ticket, the files will be ready to download."
               FontSize="13"
               Opacity="0.55"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Support View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Stretch"
            MaxWidth="720"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Support, Mode=OneWay}">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <Pivot>
                        <Pivot.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4" />
                            </DataTemplate>
                        </Pivot.HeaderTemplate>

                        <!-- Venmo Tab -->
                        <PivotItem Header="Venmo QR">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                                    Padding="24"
                                    Margin="0,16,0,0">
                                <StackPanel Spacing="20">
                                    <TextBlock Text="Scan to Support via Venmo"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />

                                    <!-- QR Code -->
                                    <Border Width="220"
                                            Height="220"
                                            Padding="16"
                                            HorizontalAlignment="Center"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Background="White">
                                        <Image Source="{Binding VenmoQrImage, Mode=OneWay}"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Handle box with Copy button -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="@jitpomi"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                   VerticalAlignment="Center" />
                                        <local:HandCursorButton Padding="8"
                                                                CornerRadius="8"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Command="{Binding CopyVenmoHandleCommand, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                        </local:HandCursorButton>
                                    </StackPanel>

                                    <!-- Open Web Button -->
                                    <local:HandCursorButton HorizontalAlignment="Stretch"
                                                            Padding="0,12"
                                                            CornerRadius="{ThemeResource ControlCornerRadius}"
                                                            Command="{Binding OpenVenmoWebCommand, Mode=OneWay}"
                                                            BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
                                                            BorderThickness="1"
                                                            Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE8A7;" FontSize="18" />
                                            <TextBlock Text="Open Venmo Web" FontSize="15" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                </StackPanel>
                            </Border>
                        </PivotItem>

                        <!-- Bank Transfer Tab -->
                        <PivotItem Header="Bank Transfer">
                            <StackPanel Spacing="16" Margin="0,16,0,0">
                                <Pivot>
                                    <Pivot.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Medium" />
                                        </DataTemplate>
                                    </Pivot.HeaderTemplate>

                                    <!-- Domestic -->
                                    <PivotItem Header="Domestic (USD)">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{ThemeResource OverlayCornerRadius}"
                                                Padding="20"
                                                Margin="0,10,0,0">
                                            <StackPanel Spacing="12">
                                                <!-- Row Beneficiary -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Beneficiary Name" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="JITPOMI LLC" FontSize="14" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <local:HandCursorButton HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Command="{Binding CopyBeneficiaryCommand, Mode=OneWay}">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                                    </local:HandCursorButton>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row Account -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Account Number" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="202617088912" FontSize="14" FontFamily="Consolas" />
                                                    </StackPanel>
                                                    <local:HandCursorButton HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Command="{Binding CopyAccountCommand, Mode=OneWay}">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                                    </local:HandCursorButton>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row Routing -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Routing Number (ABA / ACH)" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="091311229" FontSize="14" FontFamily="Consolas" />
                                                    </StackPanel>
                                                    <local:HandCursorButton HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Command="{Binding CopyRoutingCommand, Mode=OneWay}">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                                    </local:HandCursorButton>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row Bank Name -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Bank Name" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="Choice Financial Group (Mercury Partner)" FontSize="14" />
                                                    </StackPanel>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row Bank Address -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Bank Address" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="4501 23rd Avenue S, Fargo, ND 58104 US" FontSize="13" />
                                                    </StackPanel>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row Beneficiary Address -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Beneficiary Address" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="5003 59th Avenue Court West, Tacoma, WA 98467 US" FontSize="13" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </PivotItem>

                                    <!-- Intl USD -->
                                    <PivotItem Header="Intl (USD)">
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{ThemeResource OverlayCornerRadius}"
                                                Padding="20"
                                                Margin="0,10,0,0">
                                            <StackPanel Spacing="12">
                                                <!-- Row SWIFT -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="SWIFT / BIC Code" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
                                                        <TextBlock Text="CHFGUS44021" FontSize="14" FontFamily="Consolas" />
                                                    </StackPanel>
                                                    <local:HandCursorButton HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Command="{Binding CopySwiftCommand, Mode=OneWay}">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                                    </local:HandCursorButton>
                                                </Grid>
                                                <MenuFlyoutSeparator />

                                                <!-- Row ABA Routing -->
                                                <Grid>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="ABA Routing Number" FontSize="11" Opacity="0.6" FontWeight="SemiBold" />
